# Your Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Which Claude model to use (this is the recommended one as of mid-2025)
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# The password you will use to log in to the app
APP_PASSWORD=change-me

# Where the SQLite database file lives (relative to /prisma folder)
DATABASE_URL="file:./dev.db"
